{
  "manifest_version": 3,
  "name": "VidDown (Video Downloader)",
  "version": "1.0",
  "description": "Mevcut sayfadaki videoyu doğrudan VidDown sunucunuz üzerinden indirir.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon.png"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "viddown-extension@viddown.app",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "activeTab",
    "storage",
    "downloads",
    "notifications"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}